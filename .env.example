# Copy this to .env and fill in your values
JIRA_TOKEN=your_jira_token
JIRA_SERVER_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@company.com

GITHUB_CLOUD_TOKEN=ghp_your_cloud_token
GITHUB_ENT_TOKEN=ghp_your_enterprise_token
GITHUB_ENT_URL=https://github.yourcompany.com/api/v3

# When running via the VS Code extension, the extension starts a local LM server
# using vscode.lm (GitHub Copilot) and sets these automatically.
# For standalone Flask usage, point at any OpenAI-compatible endpoint:
OPENAI_API_BASE=http://localhost:8081
OPENAI_API_KEY=vscode-lm

PORT=3456
