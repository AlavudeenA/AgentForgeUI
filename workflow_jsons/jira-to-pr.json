{
  "workflow_name": "JIRA Story to Pull Request",
  "name": "jira-to-pr",
  "agents": [
    {
      "name": "jira_story_details_agent",
      "input": {
        "jira_issue_key": "",
        "fetch_attachments": "no"
      }
    },
    {
      "name": "copilot_agent",
      "input": {
        "prompt": "Based on the following JIRA story, write the implementation code.\n\nTitle: {state['jira_story_details_agent_output']['title']}\n\nDescription: {state['jira_story_details_agent_output']['description']}\n\nAcceptance Criteria: {state['jira_story_details_agent_output']['acceptance_criteria']}",
        "language": "python",
        "context": ""
      },
      "human_loop": {
        "enabled": true,
        "timeout": 300
      }
    },
    {
      "name": "github_createpullRequest_agent",
      "input": {
        "repo": "",
        "head_branch": "feature/{state['jira_story_details_agent_output']['issue_key']}",
        "base_branch": "main",
        "pr_title": "[{state['jira_story_details_agent_output']['issue_key']}] {state['jira_story_details_agent_output']['title']}",
        "pr_body": "## Summary\n\n{state['jira_story_details_agent_output']['description']}\n\n## Generated Code\n\n```\n{state['copilot_agent_output']['generated_code']}\n```",
        "token_type": "cloud"
      }
    }
  ]
}
