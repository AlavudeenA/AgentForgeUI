{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Agentic Forge Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode-extension"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode-extension/out/**/*.js"
      ],
      "preLaunchTask": "Compile Extension",
      "env": {
        "VSCODE_DEBUG_MODE": "true"
      }
    }
  ]
}
